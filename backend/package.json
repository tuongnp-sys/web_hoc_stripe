{
  "name": "backend",
  "version": "2.0.0",
  "description": "Stripe payment API — Express + PostgreSQL (Neon)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node -e \"require('./src/config').validateConfig(); require('./src/db/migrate').migrate().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "smoke": "node scripts/smoke-test.js",
    "smoke:prod": "node scripts/prod-smoke.js",
    "smoke:admin": "node scripts/admin-access-smoke.js",
    "seed:admin": "node -e \"require('./src/config').validateConfig(); require('./src/services/devSeed').ensureDevAdmin().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "seed:oauth": "node scripts/seed-oauth-config.js",
    "sync:render": "node scripts/sync-render-env.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "stripe": "^22.2.0"
  }
}
