# Neon — docs/NEON_SETUP.md
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Stripe test — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe live (optional — enable when production domain is ready)
# STRIPE_SECRET_KEY_LIVE=sk_live_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
# STRIPE_LIVE_ALLOWED=true

# Optional: fixed Stripe Price IDs
# STRIPE_PRICE_GOLD_STARTER=price_...
# STRIPE_PRICE_GOLD_POPULAR=price_...
# STRIPE_PRICE_GOLD_PRO=price_...
# STRIPE_PRICE_GOLD_MEGA=price_...
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...

JWT_SECRET=your-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Email (Resend) — see docs/EMAIL_SETUP.md
# Sandbox (onboarding@resend.dev) only sends to your Resend account email
# RESEND_API_KEY=re_...
# EMAIL_FROM=Gold Rush <onboarding@resend.dev>

# OAuth (optional — social login buttons hidden if unset)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# DISCORD_CLIENT_ID=...
# DISCORD_CLIENT_SECRET=...

# Render deploy sync — https://dashboard.render.com/u/settings#api-keys
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_NAME=web-hoc-stripe
API_PUBLIC_URL=http://localhost:3000

# Admin API (production); dev mode does not require
# ADMIN_SECRET=dev-only-admin

PORT=3000
CLIENT_URL=http://localhost:5173

# Optional: enable after configuring Stripe Tax head office address
# STRIPE_TAX_ENABLED=true
