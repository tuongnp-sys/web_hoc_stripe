# Neon — docs/NEON_SETUP.md
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Tùy chọn: Price ID cố định (nếu không dùng, API tạo price_data động)
# STRIPE_PRICE_GAME_UNLOCK=price_...
# STRIPE_PRICE_PREMIUM_MONTHLY=price_...

JWT_SECRET=your-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Admin API (production); dev mode không cần
# ADMIN_SECRET=dev-only-admin

PORT=3000
CLIENT_URL=http://localhost:5173

# EXTRA_CORS_ORIGINS=https://your-app.vercel.app
